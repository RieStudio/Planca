<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@drawable/widget_background">

    <!-- Header Area -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentLeft="true">
            
            <TextView
                android:id="@+id/widget_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUGÜNÜN GÖREVLERİ"
                android:textColor="#38BDF8"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/widget_header_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Çarşamba, 24 Haziran"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
                
        </LinearLayout>

        <TextView
            android:id="@+id/widget_count_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:text="5 Görev"
            android:textColor="#94A3B8"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="#15FFFFFF"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="14dp" />

    <!-- Task List (up to 5 tasks) -->
    <LinearLayout
        android:id="@+id/widget_tasks_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Task Row 1 -->
        <LinearLayout
            android:id="@+id/widget_task_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#08FFFFFF"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="6dp">
            <ImageView
                android:id="@+id/widget_check_1"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_widget_check_off" />
            <FrameLayout
                android:layout_width="10dp"
                android:layout_height="match_parent" />
            <TextView
                android:id="@+id/widget_task_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Görev 1"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/widget_dot_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- Task Row 2 -->
        <LinearLayout
            android:id="@+id/widget_task_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#08FFFFFF"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="6dp">
            <ImageView
                android:id="@+id/widget_check_2"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_widget_check_off" />
            <FrameLayout
                android:layout_width="10dp"
                android:layout_height="match_parent" />
            <TextView
                android:id="@+id/widget_task_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Görev 2"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/widget_dot_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- Task Row 3 -->
        <LinearLayout
            android:id="@+id/widget_task_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#08FFFFFF"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="6dp">
            <ImageView
                android:id="@+id/widget_check_3"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_widget_check_off" />
            <FrameLayout
                android:layout_width="10dp"
                android:layout_height="match_parent" />
            <TextView
                android:id="@+id/widget_task_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Görev 3"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/widget_dot_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- Task Row 4 -->
        <LinearLayout
            android:id="@+id/widget_task_row_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#08FFFFFF"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="6dp">
            <ImageView
                android:id="@+id/widget_check_4"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_widget_check_off" />
            <FrameLayout
                android:layout_width="10dp"
                android:layout_height="match_parent" />
            <TextView
                android:id="@+id/widget_task_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Görev 4"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/widget_dot_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- Task Row 5 -->
        <LinearLayout
            android:id="@+id/widget_task_row_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#08FFFFFF"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">
            <ImageView
                android:id="@+id/widget_check_5"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_widget_check_off" />
            <FrameLayout
                android:layout_width="10dp"
                android:layout_height="match_parent" />
            <TextView
                android:id="@+id/widget_task_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Görev 5"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/widget_dot_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:includeFontPadding="false" />
        </LinearLayout>

    </LinearLayout>

    <!-- Empty indicator -->
    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Yapılacak hiçbir görev kalmadı!"
        android:textColor="#94A3B8"
        android:textSize="11sp"
        android:gravity="center"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="12dp" />

    <!-- Footer Quick Add Bar -->
    <LinearLayout
        android:id="@+id/widget_footer_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#15FFFFFF"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">
        
        <ImageView
            android:id="@+id/widget_add_button"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_widget_add" />

        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/widget_add_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yeni Görev Ekle"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
